{
  "doctype": "Print Format",
  "name": "ZATCA Advance Tax Invoice",
  "doc_type": "ZATCA Advance Tax Invoice",
  "module": "Zatca Erpgulf",
  "standard": "Yes",
  "custom_format": 1,
  "print_format_type": "Jinja",
  "disabled": 0,
  "html": "<!DOCTYPE html>\n\n<style type=\"text/css\">\n    .zadv-original {\n        color: black;\n        font-family: Arial, sans-serif;\n        font-size: 10.5pt;\n        line-height: 1.25;\n    }\n\n    .zadv-original * {\n        box-sizing: border-box;\n    }\n\n    .zadv-original p {\n        color: black;\n        font-family: Arial, sans-serif;\n        font-size: 10.5pt;\n        margin: 0;\n        padding: 0;\n        text-indent: 0;\n    }\n\n    .zadv-original .s1 {\n        color: black;\n        font-family: Arial, sans-serif;\n        font-weight: normal;\n        font-size: 10.5pt;\n        margin: 0;\n        padding: 0;\n    }\n\n    .zadv-original .s2 {\n        color: black;\n        font-family: Arial, sans-serif;\n        font-weight: bold;\n        font-size: 9pt;\n        margin: 0;\n        padding: 0;\n    }\n\n    .zadv-original table,\n    .zadv-original tbody {\n        vertical-align: top;\n        overflow: visible;\n    }\n\n    .zadv-original table {\n        border-collapse: collapse;\n        width: 100%;\n    }\n\n    .zadv-original .top-info td {\n        padding: 0 !important;\n    }\n\n    .zadv-original .meta-label-en {\n        width: 96pt;\n        border-top: 1pt solid #DBDBDB;\n        border-bottom: 1pt solid #DBDBDB;\n        background-color: #E7E9EB;\n        padding-left: 6pt !important;\n        text-align: left;\n        height: 18px;\n    }\n\n    .zadv-original .meta-value {\n        width: 236pt;\n        border-top: 1pt solid #DBDBDB;\n        border-left: 1pt solid #DBDBDB;\n        border-bottom: 1pt solid #DBDBDB;\n        text-align: center;\n        height: 18px;\n        padding-left: 3pt !important;\n    }\n\n    .zadv-original .meta-label-ar {\n        width: 108pt;\n        border-top: 1pt solid #DBDBDB;\n        border-bottom: 1pt solid #DBDBDB;\n        border-right: 1pt solid #DBDBDB;\n        background-color: #E7E9EB;\n        text-align: right;\n        height: 18px;\n        direction: rtl;\n    }\n\n    .zadv-original .qr-flex {\n        text-align: left;\n        vertical-align: middle;\n    }\n\n    .zadv-original .qr-placeholder {\n        width: 90px;\n        height: 90px;\n        border: 1px dashed #999;\n        color: #666;\n        display: table-cell;\n        text-align: center;\n        vertical-align: middle;\n        font-size: 10pt;\n    }\n\n    .zadv-original .title {\n        text-align: center;\n        margin: 12px 0 12px 0;\n    }\n\n    .zadv-original .title-en {\n        font-size: 20pt;\n        font-weight: normal;\n        text-transform: uppercase;\n    }\n\n    .zadv-original .title-ar {\n        font-size: 18pt;\n        font-weight: normal;\n        direction: rtl;\n    }\n\n    .zadv-original .parties-table td {\n        width: 50%;\n        padding: 0 !important;\n        vertical-align: top;\n    }\n\n    .zadv-original .party-left {\n        text-align: left;\n        padding-right: 10px !important;\n    }\n\n    .zadv-original .party-right {\n        text-align: right;\n        direction: rtl;\n        padding-left: 10px !important;\n    }\n\n    .zadv-original .item-table {\n        margin-top: 14px;\n        font-size: 8pt;\n        border-collapse: collapse;\n    }\n\n    .zadv-original .item-table th,\n    .zadv-original .item-table td {\n        border: 1px solid #DBDBDB;\n        padding: 5px !important;\n    }\n\n    .zadv-original .item-table th {\n        background-color: #E7E9EB;\n        font-weight: bold;\n    }\n\n    .zadv-original .text-right {\n        text-align: right;\n    }\n\n    .zadv-original .text-center {\n        text-align: center;\n    }\n\n    .zadv-original .invoice-summary {\n        width: 100%;\n        margin-top: 8px;\n    }\n\n    .zadv-original .notes-table,\n    .zadv-original .totals-table {\n        width: 49.7%;\n        font-size: 9pt;\n        border-collapse: collapse;\n        display: inline-table;\n        vertical-align: top;\n    }\n\n    .zadv-original .notes-table td {\n        min-height: 80px;\n        padding: 5px !important;\n        vertical-align: top;\n    }\n\n    .zadv-original .totals-table td {\n        border: 1px solid #DBDBDB;\n        padding: 5px !important;\n    }\n\n    .zadv-original .totals-label {\n        background-color: white;\n        font-weight: normal;\n        width: 37%;\n    }\n\n    .zadv-original .totals-value {\n        font-size: 8pt;\n        background-color: #FFFFFF;\n        width: 30%;\n        text-align: right;\n    }\n\n    .zadv-original .arabic-label {\n        text-align: right;\n        direction: rtl;\n        width: 33%;\n    }\n\n    .zadv-original .totals-grand {\n        font-weight: bold;\n    }\n\n    .zadv-original .noBorder td {\n        border: 0;\n    }\n\n    .zadv-original .footer-note {\n        margin-top: 10px;\n        text-align: center;\n        font-size: 8pt;\n        color: #555;\n    }\n</style>\n\n{% set supplier_name_en = doc.company_name or doc.company %}\n{% set supplier_name_ar = doc.company_name_arabic or \"\" %}\n{% set customer_name_en = doc.customer_name or doc.customer %}\n{% set customer_name_ar = doc.customer_name_arabic or \"\" %}\n{% set currency = doc.currency or \"SAR\" %}\n{% set terms_html = doc.terms or \"\" %}\n{% set qr_src = doc.qr_code or doc.get(\"ksa_einv_qr\") %}\n{% set invoice_status = doc.status or (\"Submitted\" if doc.docstatus == 1 else \"Draft\") %}\n\n{% set company_default_lh = frappe.db.get_value(\"Company\", doc.company, \"default_letter_head\") if doc.company else \"\" %}\n{% set resolved_lh_name = doc.letter_head or company_default_lh %}\n{% set resolved_lh = letter_head %}\n{% if not resolved_lh and resolved_lh_name %}\n    {% set resolved_lh = frappe.db.get_value(\"Letter Head\", resolved_lh_name, \"content\") %}\n{% endif %}\n\n{% set customer_meta = frappe.get_meta(\"Customer\") %}\n{% set address_meta = frappe.get_meta(\"Address\") %}\n{% set customer_cr = frappe.db.get_value(\"Customer\", doc.customer, \"cr_number\") if doc.customer and customer_meta.has_field(\"cr_number\") else \"\" %}\n{% set company_address_doc = frappe.get_doc(\"Address\", doc.company_address) if doc.company_address else None %}\n{% set customer_address_doc = frappe.get_doc(\"Address\", doc.customer_address) if doc.customer_address else None %}\n{% set company_address_ar = company_address_doc.address_in_arabic if company_address_doc and address_meta.has_field(\"address_in_arabic\") else \"\" %}\n{% set customer_address_ar = customer_address_doc.address_in_arabic if customer_address_doc and address_meta.has_field(\"address_in_arabic\") else \"\" %}\n\n<div class=\"zadv-original\">\n\n    {% if resolved_lh %}\n        <div class=\"letter-head\">\n            {{ resolved_lh }}\n        </div>\n    {% endif %}\n\n    <div class=\"title\">\n        <div class=\"title-en\">{{ doc.print_heading or \"ADVANCE TAX INVOICE\" }}</div>\n        <div class=\"title-ar\">فاتورة ضريبية لدفعة مقدمة</div>\n    </div>\n\n    <table class=\"top-info\" align=\"center\" cellspacing=\"0\">\n        <tr>\n            <td style=\"width:15%; text-align:left; vertical-align:middle;\">\n                {% if qr_src %}\n                    <div class=\"qr-flex\">\n                        <img style=\"width:90px; height:90px;\" src=\"{{ qr_src }}\">\n                    </div>\n                {% else %}\n                    <div class=\"qr-placeholder\">QR</div>\n                {% endif %}\n            </td>\n\n            <td style=\"width:85%; text-align:right;\">\n                <table align=\"right\" cellspacing=\"0\">\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">Invoice NO</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ doc.name }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">رقم الفاتورة</p></td>\n                    </tr>\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">Invoice Date</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ doc.posting_date or \"\" }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">تاريخ الفاتورة</p></td>\n                    </tr>\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">Payment Entry</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ doc.payment_entry or \"\" }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">سند القبض</p></td>\n                    </tr>\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">Invoice Type Code</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ doc.invoice_type_code or \"386\" }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">رمز نوع الفاتورة</p></td>\n                    </tr>\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">Invoice Status</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ invoice_status }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">حالة الفاتورة</p></td>\n                    </tr>\n                    <tr>\n                        <td class=\"meta-label-en\"><p class=\"s2\">ZATCA Status</p></td>\n                        <td class=\"meta-value\"><p class=\"s1\">{{ doc.zatca_status or \"Not Submitted\" }}</p></td>\n                        <td class=\"meta-label-ar\"><p class=\"s2\">حالة هيئة الزكاه</p></td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n    </table>\n\n    <p style=\"text-align:left;\"><br></p>\n\n    <table class=\"parties-table\" cellspacing=\"0\">\n        <tr>\n            <td class=\"party-left\">\n                <p><b>Invoice from:</b> <b>{{ supplier_name_en }}</b></p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>فاتورة من:</b> <b>{{ supplier_name_ar }}</b></p>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"party-left\">\n                <p><b>VAT Number:</b> {{ doc.company_vat_number or \"\" }}</p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>الرقم الضريبي:</b> {{ doc.company_vat_number or \"\" }}</p>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"party-left\">\n                <p>\n                    <b>Address:</b>\n                    {{ doc.company_address_line1 or \"\" }}\n                    {% if doc.company_address_line2 %} {{ doc.company_address_line2 }}{% endif %}\n                </p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>العنوان:</b> {{ company_address_ar or doc.company_address_line1 or \"\" }}</p>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"party-left\">\n                <p><b>To:</b> <b>{{ customer_name_en }}</b></p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>إلى:</b> <b>{{ customer_name_ar }}</b></p>\n            </td>\n        </tr>\n\n        <tr>\n            <td class=\"party-left\">\n                <p><b>VAT Number:</b> {{ doc.customer_vat_number or \"\" }}</p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>الرقم الضريبي:</b> {{ doc.customer_vat_number or \"\" }}</p>\n            </td>\n        </tr>\n\n        {% if customer_cr %}\n        <tr>\n            <td class=\"party-left\">\n                <p><b>CR No.:</b> {{ customer_cr }}</p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>رقم السجل التجاري:</b> {{ customer_cr }}</p>\n            </td>\n        </tr>\n        {% endif %}\n\n        <tr>\n            <td class=\"party-left\">\n                <p>\n                    <b>Address:</b>\n                    {{ doc.customer_address_line1 or \"\" }}\n                    {% if doc.customer_address_line2 %} {{ doc.customer_address_line2 }}{% endif %}\n                </p>\n            </td>\n            <td class=\"party-right\">\n                <p><b>العنوان:</b> {{ customer_address_ar or doc.customer_address_line1 or \"\" }}</p>\n            </td>\n        </tr>\n    </table>\n\n    <table class=\"item-table table table-bordered\">\n        <thead>\n            <tr>\n                <th colspan=\"8\" class=\"text-right\">توصيف السلعة</th>\n            </tr>\n            <tr>\n                <th style=\"width:5%;\">#</th>\n                <th style=\"width:28%;\">اسم الصنف<br>Item Name</th>\n                <th class=\"text-right\" style=\"width:9%;\">الكمية<br>Qty</th>\n                <th class=\"text-right\" style=\"width:13%;\">سعر الوحدة<br>unit price</th>\n                <th class=\"text-right\" style=\"width:13%;\">المجموع<br>Total</th>\n                <th class=\"text-right\" style=\"width:9%;\">الضرائب%<br>VAT%</th>\n                <th class=\"text-right\" style=\"width:11%;\">مبلغ الضريبة<br>VAT Amount</th>\n                <th class=\"text-right\" style=\"width:12%;\">الإجمالي بالضريبة<br>Amount With Vat</th>\n            </tr>\n        </thead>\n        <tbody>\n            <tr>\n                <td>1</td>\n                <td class=\"text-right\">{{ doc.description or doc.tax_description or \"Advance Payment\" }}</td>\n                <td class=\"text-right\">1</td>\n                <td class=\"text-right\">{{ \"{:,.2f}\".format(doc.taxable_amount or 0) }}</td>\n                <td class=\"text-right\">{{ \"{:,.2f}\".format(doc.taxable_amount or 0) }}</td>\n                <td class=\"text-right\">{{ \"{:,.2f}\".format(doc.tax_rate or 0) }}%</td>\n                <td class=\"text-right\">{{ \"{:,.2f}\".format(doc.tax_amount or 0) }}</td>\n                <td class=\"text-right\">{{ \"{:,.2f}\".format(doc.total_amount or 0) }}</td>\n            </tr>\n        </tbody>\n    </table>\n\n    <div class=\"invoice-summary\">\n        <table class=\"notes-table\">\n            <tbody>\n                <tr>\n                    <td>\n                        <p class=\"notes-heading\">Notes ملاحظات</p>\n                        {% if terms_html %}\n                            <p class=\"notes-content\">{{ terms_html }}</p>\n                        {% endif %}\n                    </td>\n                </tr>\n                <tr><td colspan=\"4\">&nbsp;</td></tr>\n                <tr><td colspan=\"4\">&nbsp;</td></tr>\n                <tr><td colspan=\"4\">&nbsp;</td></tr>\n            </tbody>\n        </table>\n\n        <table class=\"totals-table\">\n            <tbody>\n                <tr>\n                    <td class=\"totals-label\">currency</td>\n                    <td class=\"totals-value\">{{ currency }}</td>\n                    <td class=\"totals-label arabic-label\">العملة</td>\n                </tr>\n                <tr>\n                    <td class=\"totals-label\">Total excl. VAT</td>\n                    <td class=\"totals-value\">{{ \"{:,.2f}\".format(doc.taxable_amount or 0) }}</td>\n                    <td class=\"totals-label arabic-label\">المبلغ بدون اضافة الضريبة</td>\n                </tr>\n                <tr>\n                    <td class=\"totals-label\">Total VAT</td>\n                    <td class=\"totals-value\">{{ \"{:,.2f}\".format(doc.tax_amount or 0) }}</td>\n                    <td class=\"totals-label arabic-label\">ضريبة القيمة المضافة</td>\n                </tr>\n                <tr>\n                    <td class=\"totals-label totals-grand\">Net Payable</td>\n                    <td class=\"totals-value totals-grand\">{{ \"{:,.2f}\".format(doc.total_amount or 0) }}</td>\n                    <td class=\"totals-label totals-grand arabic-label\">اجمالي المبلغ المستحق</td>\n                </tr>\n                <tr>\n                    <td class=\"totals-label\" colspan=\"3\" style=\"text-align:right;\">\n                        <strong>In Words: </strong>{{ doc.in_words or \"\" }}\n                    </td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n\n    <div class=\"footer-note\">\n        Advance Tax Invoice generated from Payment Entry {{ doc.payment_entry or \"\" }}.\n        UUID: {{ doc.zatca_uuid or \"\" }}\n    </div>\n</div>\n",
  "raw_printing": 0,
  "align_labels_right": 0,
  "show_section_headings": 0,
  "line_breaks": 0,
  "absolute_value": 0,
  "font": "Default",
  "font_size": 10,
  "css": "",
  "print_format_builder": 0,
  "idx": 0
}
